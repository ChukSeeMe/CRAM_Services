# Copy this file to .env.local and fill in the values
# NEVER commit .env.local or .env.production to git

PORT=4000
NEXT_PUBLIC_API_URL=https://tutorflow-backend.whitesea-c505a8c9.uksouth.azurecontainerapps.io

# Admin auth — server-side ONLY, never use NEXT_PUBLIC_ prefix
ADMIN_PASSWORD=your_admin_password

# PostgreSQL (Azure or local)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Resend email service
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=CRAM Services <onboarding@resend.dev>
EMAIL_REPLY_TO=cramserviceshub@gmail.com
